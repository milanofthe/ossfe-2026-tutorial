      }
    ]
  },
  "events": [],
  "codeContext": {
    "code": "# Superconducting magnet parameters\nL = 10.0           # coil inductance [H]\nI0 = 20.0          # initial current [kA]\nR_dump = 0.05      # dump resistor [Ohm]\nR_quench = 0.5     # quench zone resistance [Ohm]\nt_quench = 1.0     # quench onset [s]\n\ndef R_total(t):\n    if t < t_quench:\n        return R_dump\n    return R_dump + R_quench"
  },
